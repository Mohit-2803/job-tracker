{
  "name": "job-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:all": "concurrently -c \"cyan.bold,yellow.bold\" -n \"WEB,WORKER\" \"npm run dev\" \"npm run worker\"",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "worker": "tsx --env-file=.env src/workers/scraper-worker.ts",
    "format": "prettier --write ."
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
