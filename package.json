    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.51.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "ai": "^6.0.168",
    "bullmq": "^5.76.4",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
