    "prisma": "^6.19.3",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
