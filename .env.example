# Database (Docker local dev)
DATABASE_URL="postgresql://postgres:localpass@localhost:5432/jobagent"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"

# GitHub OAuth — github.com/settings/developers → New OAuth App
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Google OAuth — console.cloud.google.com → OAuth 2.0 Client ID
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Redis (Docker local dev)
REDIS_URL="redis://localhost:6379"

# Groq AI — console.groq.com
GROQ_API_KEY="gsk_xxxxxxxxxxxx"

# Gemini (backup LLM) — ai.google.dev
GEMINI_API_KEY="xxxxxxxxxxxx"

# Resend Email — resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Job Agent <noreply@yourdomain.com>"

# Razorpay (Test Mode) — razorpay.com
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="xxxxxxxxxxxx"
RAZORPAY_PRO_MONTHLY_PLAN_ID="plan_xxxxxxxxxxxx"

# File Storage — cloudinary.com
CLOUDINARY_CLOUD_NAME="xxx"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# Production URL
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Monitoring (add later)
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# POSTHOG_KEY="phc_xxx"
